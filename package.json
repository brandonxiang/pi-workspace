{
  "name": "pi-workspace",
  "version": "0.1.0",
  "description": "CLI-launched browser UI for pi-coding-agent sessions",
  "bin": {
    "pi-gui": "./bin/pi-gui.mjs"
  },
  "files": [
    "bin",
    "dist-server",
    "dist/client",
    "README.md",
    ".env.example"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@google/genai",
      "protobufjs",
      "rolldown"
    ]
  },
  "type": "module",
  "scripts": {
    "cli": "node bin/pi-gui.mjs",
    "dev": "node dev.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "build:server": "rolldown -c rolldown.server.config.mjs",
    "build:client": "vite build",
    "build": "npm run typecheck && npm run build:client && npm run build:server",
    "start": "NODE_ENV=production node dist-server/index.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@ant-design/x": "^2.7.0",
    "@earendil-works/pi-coding-agent": "0.75.5",
    "@fastify/vite": "latest",
    "@vitejs/plugin-react": "latest",
    "antd": "^6.4.3",
    "fastify": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "rolldown": "^1.1.1",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.7.0"
}