{
  "name": "my-pi",
  "version": "0.1.0",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@google/genai", "protobufjs"]
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts --dev",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "build": "pnpm run typecheck && pnpm run build:client && pnpm run build:server",
    "start": "NODE_ENV=production node dist-server/index.js"
  },
  "dependencies": {
    "@ant-design/x": "^2.7.0",
    "@earendil-works/pi-coding-agent": "0.75.5",
    "@fastify/vite": "latest",
    "@vitejs/plugin-react": "latest",
    "antd": "^6.4.3",
    "fastify": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "tsx": "latest",
    "vitest": "^4.1.7"
  }
}
